{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "HttpClient": {
    "ApiBaseURL": "https://localhost:7280/api",
    "WordTree": {
      "PathPrefix": "/Words",
      "GetById": "/{0}",
      "Add": "?vocabularyId={0}",
      "Delete": "/{0}",
      "Update": ""
    },
    "WordParserTree": {
      "PathPrefix": "/WordParser",
      "ParseByUrl": "?url={0}"
    },
    "VocabularyTree": {
      "PathPrefix": "/Vocabularies",
      "Create": "",
      "GetVocabularies": "?withWords={0}",
      "GetById": "/{0}",
      "Update": "",
      "Delete": "/{0}"
    },
    "MeaningTree": {
      "PathPrefix": "/Meanings",
      "Add": "?wordId={0}",
      "Delete": "/{0}",
      "Update": ""
    },
    "DashboardTree": {
      "PathPrefix": "/Dashboard",
      "TopWords": "/top-words",
      "TopVocabularies": "/top-vocabularies"
    }
  },
  "AllowedHosts": "*"
}
