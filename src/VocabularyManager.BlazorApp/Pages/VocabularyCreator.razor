@page "/vocabularycraft"
@attribute [Authorize(Roles = "Administrator")]

@using VocabularyManager.BlazorApp.Models
@using VocabularyManager.BlazorApp.Models.Views
@using VocabularyManager.BlazorApp.Pages.Components
@using VocabularyManager.BlazorApp.Pages.Modals
@using VocabularyManager.BlazorApp.Services
@using VocabularyManager.UseCases.DTOs

@inject HttpService HttpService
@inject HttpPathBuilder HttpPathBuilder
@inject IStringLocalizer<SharedResource> SharedLoc
@inject IStringLocalizer<VocabularyCreatorResource> Loc

<div class="container bg-light rounded-1 border-2">
    <h3>@Loc["Title"]</h3>
    <div class="row">
        <Tabs>
            <Tab Title="@Loc["FromFile"]">
                <Content>
                    <div class="col mb-3 mt-3">
                        <div class="input-group mb-2">
                            <InputFile OnChange="LoadFiles" class="form-control" accept=".csv" />
                            <Button Color="ButtonColor.Primary" @onclick="ParseSchema" Disabled="@(csvContent.Count == 0)">
                                @Loc["ParseSchema"]
                            </Button>
                        </div>
                        
                        @if (csvParseResult != null && csvParseResult.IsSuccess && showMappingUI)
                        {
                            <CsvFieldMappingPanel 
                                FieldMappings="fieldMappings"
                                CsvHeaders="csvParseResult.Headers"
                                IncludeMeanings="includeMeanings"
                                IncludeMeaningsChanged="OnIncludeMeaningsChanged"
                                OnApplyMapping="ApplyMapping"
                                OnCancelMapping="CancelMapping" />
                        }
                        else if (csvParseResult != null && !csvParseResult.IsSuccess)
                        {
                            <div class="alert alert-danger mt-2">
                                @SharedLoc[csvParseResult.ErrorMessage!]
                            </div>
                        }
                    </div>
                </Content>
            </Tab>
            <Tab Title="@Loc["FromOxfordVocabulary"]">
                <Content>
                    <OxfordVocabularyLoader 
                        IsLoading="areWordsLoading"
                        OnLoadVocabulary="LoadVocabularyFromUrl" />
                </Content>
            </Tab>
        </Tabs>
        
        @if (!areWordsLoading && WordList.Count > 0)
        {
            <div class="m-1">
                <hr />
            </div>
            
            <div class="flex-row">
                <VocabularySavePanel 
                    ExistingVocabularies="existingVocabularies"
                    IsSaving="isListSaving"
                    IsLoadingVocabularies="isLoadingVocabularies"
                    OnSaveVocabulary="HandleSaveVocabulary"
                    OnRefreshVocabularies="LoadExistingVocabularies" />
            </div>
            
            <WordPreviewList @ref="wordPreviewList" Words="WordList" PageSize="50" />
        }
        else if (areWordsLoading)
        {
            <div class="text-primary text-center align-content-center">
                @SharedLoc["State_Loading"]
            </div>
        }
    </div>
</div>

<Modal @ref="modalResult" />

@code {
    private List<WordDTO> WordList = new List<WordDTO>();

    private bool areWordsLoading = false;
    private bool isListSaving = false;
    private readonly IList<string> csvContent = [];

    private Modal modalResult = default!;
    private WordPreviewList? wordPreviewList;

    private CsvParserService csvParser = new CsvParserService();
    private CsvParseResult? csvParseResult;
    private List<CsvFieldMapping> fieldMappings = new();
    private bool showMappingUI = false;
    private bool includeMeanings = true;

    private List<VocabularyView> existingVocabularies = new();
    private bool isLoadingVocabularies = false;

    private async Task LoadVocabularyFromUrl(string url)
    {
        areWordsLoading = true;
        WordList.Clear();
        
        HttpResponseMessage response = await HttpService.GetAsync(
            HttpPathBuilder.ParseListOfWordEndpoint(url));

        if (response.IsSuccessStatusCode)
        {
            PlainListOfWordsResponseDTO? list = await response.Content
                .ReadFromJsonAsync<PlainListOfWordsResponseDTO>();
            if (list is not null && list.Words.Any())
            {
                WordList.AddRange(
                    list.Words.Select(s => new WordDTO(s)));
            }
        }
        else
        {
            await ShowModalMessage(title: Loc["Oops"], message: Loc["ProblemOccurred"]);
        }

        areWordsLoading = false;
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        csvContent.Clear();
        csvParseResult = null;
        showMappingUI = false;
        WordList.Clear();

        using MemoryStream memoryStream = new();
        await e.File.OpenReadStream().CopyToAsync(memoryStream);
        memoryStream.Position = 0;
        using StreamReader streamReader = new(memoryStream);

        while (await streamReader.ReadLineAsync() is { } line)
        {
            csvContent.Add(line);
        }
    }

    private void ParseSchema()
    {
        if (csvContent.Count == 0)
        {
            return;
        }

        csvParseResult = csvParser.ParseCsv(csvContent);
        
        if (csvParseResult.IsSuccess)
        {
            fieldMappings = WordModelProperties.GetMappingFields(SharedLoc);
            showMappingUI = true;
        }
    }

    private void ApplyMapping()
    {
        if (csvParseResult == null)
        {
            return;
        }

        WordList.Clear();

        Dictionary<string, int> columnIndices = new Dictionary<string, int>();
        for (int i = 0; i < csvParseResult.Headers.Count; i++)
        {
            columnIndices[csvParseResult.Headers[i]] = i;
        }

        foreach (List<string> row in csvParseResult.DataRows)
        {
            WordDTO word = new WordDTO();
            MeaningDTO meaning = new MeaningDTO();
            bool hasMeaningData = false;

            foreach (CsvFieldMapping mapping in fieldMappings)
            {
                if (string.IsNullOrEmpty(mapping.CsvColumnName))
                    continue;

                if (mapping.IsMeaningProperty && !includeMeanings)
                    continue;

                if (!columnIndices.TryGetValue(mapping.CsvColumnName, out int colIndex))
                    continue;

                if (colIndex >= row.Count)
                    continue;

                string value = row[colIndex];

                switch (mapping.ModelProperty)
                {
                    case WordModelProperties.WordContent:
                        word.WordContent = value;
                        break;
                    case WordModelProperties.LexemeType:
                        meaning.LexemeType = value;
                        if (!string.IsNullOrWhiteSpace(value)) hasMeaningData = true;
                        break;
                    case WordModelProperties.Level:
                        meaning.Level = value;
                        if (!string.IsNullOrWhiteSpace(value)) hasMeaningData = true;
                        break;
                    case WordModelProperties.Definition:
                        meaning.Definition = value;
                        if (!string.IsNullOrWhiteSpace(value)) hasMeaningData = true;
                        break;
                }
            }

            if (!string.IsNullOrWhiteSpace(word.WordContent))
            {
                if (includeMeanings && hasMeaningData)
                {
                    word.Meanings.Add(meaning);
                }
                WordList.Add(word);
            }
        }

        showMappingUI = false;
        wordPreviewList?.ResetPage();
    }

    private void CancelMapping()
    {
        showMappingUI = false;
        csvParseResult = null;
        fieldMappings.Clear();
        includeMeanings = true;
    }

    private void OnIncludeMeaningsChanged(bool value)
    {
        includeMeanings = value;
    }

    private async Task HandleSaveVocabulary(SaveVocabularyRequest request)
    {
        isListSaving = true;

        if (request.SaveToNew)
        {
            await SaveToNewVocabulary(request.VocabularyName);
        }
        else
        {
            await SaveToExistingVocabulary(request.SelectedVocabularyId);
        }

        isListSaving = false;
    }

    private async Task SaveToNewVocabulary(string vocabularyName)
    {
        if (string.IsNullOrEmpty(vocabularyName))
        {
            await ShowModalMessage(Loc["Warning"], Loc["PleaseSetVocabularyName"]);
            return;
        }

        HttpResponseMessage vocabularyCreationResponse = await HttpService.PostWithJsonAsync<VocabularyView>(
            HttpPathBuilder.CreateVocabularyEndpoint(),
            new VocabularyView(vocabularyName, null)
        );
        
        if (!vocabularyCreationResponse.IsSuccessStatusCode)
        {
            await ShowModalMessage(Loc["Oops"], await vocabularyCreationResponse.Content.ReadAsStringAsync());
            return;
        }

        int vocabularyId = int.Parse(await vocabularyCreationResponse.Content.ReadAsStringAsync());
        await SaveWordsToVocabulary(vocabularyId, vocabularyName);
    }

    private async Task SaveToExistingVocabulary(int vocabularyId)
    {
        if (vocabularyId == 0)
        {
            await ShowModalMessage(Loc["Warning"], Loc["PleaseSelectVocabulary"]);
            return;
        }

        VocabularyView? selectedVocab = existingVocabularies.FirstOrDefault(v => v.Id == vocabularyId);
        string vocabName = selectedVocab?.Name ?? Loc["SelectedVocabulary"];
        await SaveWordsToVocabulary(vocabularyId, vocabName);
    }

    private async Task SaveWordsToVocabulary(int vocabularyId, string vocabularyName)
    {
        HttpResponseMessage wordsSavingResponse = await HttpService.PostWithJsonAsync<IEnumerable<WordDTO>>(
            HttpPathBuilder.AddWordEndpoint(vocabularyId),
            WordList
        );
        
        if (wordsSavingResponse.IsSuccessStatusCode)
        {
            await ShowModalMessage(Loc["GoodJob"], string.Format(Loc["VocabularySavedWithWords"], vocabularyName, WordList.Count));
        }
        else
        {
            await ShowModalMessage(Loc["Oops"], Loc["OperationFailed"]);
        }
    }

    private async Task LoadExistingVocabularies()
    {
        isLoadingVocabularies = true;
        
        try
        {
            HttpResponseMessage response = await HttpService.GetAsync(
                HttpPathBuilder.GetVocabulariesEndpoint());

            if (response.IsSuccessStatusCode)
            {
                IEnumerable<VocabularyView>? vocabularies = await response.Content.ReadFromJsonAsync<IEnumerable<VocabularyView>>();
                existingVocabularies = vocabularies?.ToList() ?? new List<VocabularyView>();
            }
            else
            {
                await ShowModalMessage(Loc["Error"], Loc["FailedToLoadVocabularies"]);
            }
        }
        catch (Exception ex)
        {
            await ShowModalMessage(Loc["Error"], string.Format(Loc["FailedToLoadVocabulariesMessage"], ex.Message));
        }
        finally
        {
            isLoadingVocabularies = false;
        }
    }

    private async Task ShowModalMessage(string title, string message)
    {
        Dictionary<string, object> parameters = new Dictionary<string, object>();
        parameters.Add("Message", message);
        await modalResult.ShowAsync<ModalResult>(title: title, parameters: parameters);
    }
}
