@using FluentValidation
@using FluentValidation.Results
@using VocabularyManager.BlazorApp.Models.Views
@using VocabularyManager.BlazorApp.Services
@using VocabularyManager.BlazorApp.Interfaces

@inject HttpService HttpService
@inject HttpPathBuilder HttpPathBuilder
@inject IVocabularyStateManager<VocabularyView> VocabularyStateManager
@inject IValidator<WordView> WordValidator

<WordForm Word="word"></WordForm>
<div class="m-1">
    @if (validationErrors.Count > 0)
    {
        foreach (var error in validationErrors)
        {
            <ValidationError Error="error"></ValidationError>
        }
    }
</div>

<Button Type="ButtonType.Submit" Color="ButtonColor.Success" @onclick="CreateWord">Create</Button>
<Button Type="ButtonType.Reset" Color="ButtonColor.Danger" @onclick="OnCloseFunc">Cancel</Button>

@code {
    [Inject]
    protected ToastService ToastService { get; set; } = default!;
    [Parameter]
    public Func<Task> OnCloseFunc { get; init; }
    private WordView? word;
    private List<ValidationFailure> validationErrors = [];

    protected override void OnParametersSet()
    {
        word = new WordView("word", "level", "lexeme", null);
    }

    private async Task CreateWord()
    {
        validationErrors.Clear();
        ValidationResult result = WordValidator.Validate(word);
        if(result.IsValid)
        {
            HttpResponseMessage wordCreationResponse = await HttpService.PostWithJsonAsync<IEnumerable<WordView>>(
                HttpPathBuilder.AddWordEndpoint(VocabularyStateManager?.Vocabulary?.Id ?? -1),
                [word]
            );

            if (wordCreationResponse.IsSuccessStatusCode)
            {
                ToastService.Notify(new(ToastType.Info, "Word was successfuly created."));
                await VocabularyStateManager.Update();
                await OnCloseFunc();
            }
            else
            {
                ToastService.Notify(new(ToastType.Danger, "Sorry, creation failed."));
            }
        }
        else
        {
            validationErrors.AddRange(result.Errors);
        }
    }
}
