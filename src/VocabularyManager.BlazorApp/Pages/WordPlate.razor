@using VocabularyManager.BlazorApp.Models.Views
@using VocabularyManager.BlazorApp.Pages.Modals
@using VocabularyManager.BlazorApp.Services
@using VocabularyManager.BlazorApp.Interfaces

@inject HttpService HttpService
@inject HttpPathBuilder HttpPathBuilder
@inject IVocabularyStateManager<VocabularyView> VocabularyStateManager

<Modal @ref="editWordModal"></Modal>
<ConfirmDialog @ref="deleteConfirmationDialog"></ConfirmDialog>
@if(Word is not null)
{
    <div class="border border-1 rounded m-1 p-2">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="fw-bold text-primary">@Word?.WordContent</span>
                @if (Word?.Meanings?.Any() == true)
                {
                    <span class="badge bg-secondary ms-2" title="Number of meanings">
                        @Word.Meanings.Count @(Word.Meanings.Count == 1 ? "meaning" : "meanings")
                    </span>
                }
                else
                {
                    <span class="badge bg-light text-muted ms-2">No meanings</span>
                }
            </div>
            <div class="d-flex">
                <Button Class="m-lg-1" @onclick="ShowEditFormModal" Type="ButtonType.Link" Color="ButtonColor.Secondary" Size="Size.Small">Edit</Button>
                <Button Class="m-lg-1" @onclick="DeleteWord" Type="ButtonType.Link" Color="ButtonColor.Danger" Size="Size.Small">Delete</Button>
            </div>
        </div>
    </div>
}
else
{
    <span class="text-info">None</span>
}

@code {
    [Inject]
    protected ToastService ToastService { get; set; } = default!;
    [Parameter]
    public required WordView Word { get; set; }
    private Modal editWordModal = default!;
    private ConfirmDialog deleteConfirmationDialog = default!;

    private async Task ShowEditFormModal()
    {
        Dictionary<string, object> parameters = [];
        parameters.Add("Word", Word);
        parameters.Add("OnCloseFunc", (object)OnCloseModal);
        await editWordModal.ShowAsync<EditWordModal>(title: "EditWord", parameters: parameters);
    }

    private async Task OnCloseModal()
    {
        await editWordModal.HideAsync();
    }

    private async Task DeleteWord()
    {
        ConfirmDialogOptions dialogOptions = new ConfirmDialogOptions()
        {
            YesButtonText = "Yes, delete",
            YesButtonColor = ButtonColor.Danger,
            NoButtonText = "No, cancel",
            NoButtonColor = ButtonColor.Secondary
        };
        bool deleteForSure = await deleteConfirmationDialog.ShowAsync
        (
            "Delet word",
            $"Do you want to delete the word: \"{Word.WordContent}\"",
            dialogOptions
        );
        if(deleteForSure)
        {
            HttpResponseMessage deleteResponse = await HttpService.DeleteAsync(
                HttpPathBuilder.DeleteWordEndpoint(Word.Id)
            );
            if (deleteResponse.IsSuccessStatusCode)
            {

                ToastService.Notify(new(ToastType.Info, "Word was deleted."));
                await VocabularyStateManager.Update();

            }
            else
            {
                ToastService.Notify(new(ToastType.Danger, "Delete operation couldn't be done."));
            }
        }
    }
}
