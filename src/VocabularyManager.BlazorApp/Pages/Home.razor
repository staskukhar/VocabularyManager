@page "/"
@using VocabularyManager.UseCases.DTOs
@using VocabularyManager.BlazorApp.Models
@using VocabularyManager.BlazorApp.Interfaces
@using VocabularyManager.BlazorApp.Services
@inject HttpPathBuilder HttpPathBuilder
@inject HttpService HttpService
@inject IRecentlyOpenedService RecentlyOpenedService
@inject IStringLocalizer<SharedResource> SharedLoc
@inject IStringLocalizer<HomeResource> Loc

<PageTitle>@SharedLoc["Nav_Home"]</PageTitle>

<h1 class="mb-4">@Loc["Dashboard"]</h1>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">@Loc["TopWordsByDefinitions"]</h2>
            </div>
            <div class="card-body">
                @if (topWords.Count == 0 && !loadingWords)
                {
                    <p class="text-muted mb-0">@Loc["NoWordsYet"]</p>
                }
                @if (loadingWords)
                {
                    <p class="text-muted mb-0">@SharedLoc["State_LoadingEllipsis"]</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @foreach (TopWordByDefinitionsDto item in topWords)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <a href="/word/@item.WordId" class="text-primary text-decoration-none fw-medium">@item.WordContent</a>
                                    <span class="small text-muted ms-1">(@item.VocabularyName)</span>
                                </div>
                                <span class="badge bg-secondary">@item.DefinitionCount</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">@Loc["TopVocabulariesByWordCount"]</h2>
            </div>
            <div class="card-body">
                @if (topVocabularies.Count == 0 && !loadingVocabularies)
                {
                    <p class="text-muted mb-0">@Loc["NoVocabulariesYet"]</p>
                }
                @if (loadingVocabularies)
                {
                    <p class="text-muted mb-0">@SharedLoc["State_LoadingEllipsis"]</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @foreach (TopVocabularyByWordsDto item in topVocabularies)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <a href="/vocabulary/@item.VocabularyId" class="text-primary text-decoration-none fw-medium">@item.VocabularyName</a>
                                <span class="badge bg-secondary">@item.WordCount</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
</div>

@if (recentWords.Count > 0 || recentVocabularies.Count > 0)
{
    <div class="row g-4 mt-2">
        @if (recentWords.Count > 0)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <h2 class="h5 mb-0">@Loc["RecentlyOpenedWords"]</h2>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            @foreach (RecentItem item in recentWords)
                            {
                                <li class="list-group-item d-flex align-items-center">
                                    <a href="@GetWordLink(item)" class="text-primary text-decoration-none fw-medium">@item.Name</a>
                                    @if (item.IsGlobalMode)
                                    {
                                        <span class="badge bg-info ms-2">@SharedLoc["Global"]</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
        @if (recentVocabularies.Count > 0)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <h2 class="h5 mb-0">@Loc["RecentlyOpenedVocabularies"]</h2>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            @foreach (RecentItem item in recentVocabularies)
                            {
                                <li class="list-group-item">
                                    <a href="/vocabulary/@item.Id" class="text-primary text-decoration-none fw-medium">@item.Name</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private const int TopCount = 5;
    private List<TopWordByDefinitionsDto> topWords = new();
    private List<TopVocabularyByWordsDto> topVocabularies = new();
    private List<RecentItem> recentWords = new();
    private List<RecentItem> recentVocabularies = new();
    private bool loadingWords = true;
    private bool loadingVocabularies = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTopWordsAsync(), LoadTopVocabulariesAsync());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            recentWords = await RecentlyOpenedService.GetRecentWords();
            recentVocabularies = await RecentlyOpenedService.GetRecentVocabularies();
            StateHasChanged();
        }
    }

    private async Task LoadTopWordsAsync()
    {
        try
        {
            string path = HttpPathBuilder.GetDashboardTopWordsEndpoint(TopCount);
            HttpResponseMessage response = await HttpService.GetAsync(path);
            List<TopWordByDefinitionsDto>? list = await response.Content.ReadFromJsonAsync<List<TopWordByDefinitionsDto>>();
            topWords = list ?? new List<TopWordByDefinitionsDto>();
        }
        finally
        {
            loadingWords = false;
        }
    }

    private async Task LoadTopVocabulariesAsync()
    {
        try
        {
            string path = HttpPathBuilder.GetDashboardTopVocabulariesEndpoint(TopCount);
            HttpResponseMessage response = await HttpService.GetAsync(path);
            List<TopVocabularyByWordsDto>? list = await response.Content.ReadFromJsonAsync<List<TopVocabularyByWordsDto>>();
            topVocabularies = list ?? new List<TopVocabularyByWordsDto>();
        }
        finally
        {
            loadingVocabularies = false;
        }
    }

    private static string GetWordLink(RecentItem item)
    {
        return item.IsGlobalMode
            ? $"/word/{item.Id}?globalMode=true"
            : $"/word/{item.Id}";
    }
}
