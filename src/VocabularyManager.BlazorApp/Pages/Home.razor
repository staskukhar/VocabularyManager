@page "/"
@using VocabularyManager.UseCases.DTOs
@using VocabularyManager.BlazorApp.Services
@inject HttpPathBuilder HttpPathBuilder
@inject HttpService HttpService

<PageTitle>Home</PageTitle>

<h1 class="mb-4">Dashboard</h1>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">Top words by definitions</h2>
            </div>
            <div class="card-body">
                @if (topWords.Count == 0 && !loadingWords)
                {
                    <p class="text-muted mb-0">No words yet.</p>
                }
                @if (loadingWords)
                {
                    <p class="text-muted mb-0">Loading…</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @foreach (var item in topWords)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <a href="/word/@item.WordId" class="text-primary text-decoration-none fw-medium">@item.WordContent</a>
                                    <span class="small text-muted ms-1">(@item.VocabularyName)</span>
                                </div>
                                <span class="badge bg-secondary">@item.DefinitionCount</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">Top vocabularies by word count</h2>
            </div>
            <div class="card-body">
                @if (topVocabularies.Count == 0 && !loadingVocabularies)
                {
                    <p class="text-muted mb-0">No vocabularies yet.</p>
                }
                @if (loadingVocabularies)
                {
                    <p class="text-muted mb-0">Loading…</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @foreach (var item in topVocabularies)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <a href="/vocabulary/@item.VocabularyId" class="text-primary text-decoration-none fw-medium">@item.VocabularyName</a>
                                <span class="badge bg-secondary">@item.WordCount</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private const int TopCount = 5;
    private List<TopWordByDefinitionsDto> topWords = new();
    private List<TopVocabularyByWordsDto> topVocabularies = new();
    private bool loadingWords = true;
    private bool loadingVocabularies = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTopWordsAsync(), LoadTopVocabulariesAsync());
    }

    private async Task LoadTopWordsAsync()
    {
        try
        {
            string path = HttpPathBuilder.GetDashboardTopWordsEndpoint(TopCount);
            HttpResponseMessage response = await HttpService.GetAsync(path);
            var list = await response.Content.ReadFromJsonAsync<List<TopWordByDefinitionsDto>>();
            topWords = list ?? new List<TopWordByDefinitionsDto>();
        }
        finally
        {
            loadingWords = false;
        }
    }

    private async Task LoadTopVocabulariesAsync()
    {
        try
        {
            string path = HttpPathBuilder.GetDashboardTopVocabulariesEndpoint(TopCount);
            HttpResponseMessage response = await HttpService.GetAsync(path);
            var list = await response.Content.ReadFromJsonAsync<List<TopVocabularyByWordsDto>>();
            topVocabularies = list ?? new List<TopVocabularyByWordsDto>();
        }
        finally
        {
            loadingVocabularies = false;
        }
    }
}
