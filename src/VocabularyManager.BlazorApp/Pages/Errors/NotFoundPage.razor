@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["App_NotFound"]</PageTitle>

<div class="error-page text-center mt-5">
    <h1 class="display-1 fw-bold text-secondary">404</h1>
    <h2 class="mb-3">@Loc["App_NotFound"]</h2>
    <p class="text-muted mb-4">@Loc["App_NothingAtAddress"]</p>
    <a href="/" class="btn btn-primary">@Loc["Btn_GoHome"]</a>
</div>
