@using VocabularyManager.BlazorApp.Models.Views

@inject IStringLocalizer<SharedResource> SharedLoc

@if (Vocabulary is not null)
{
    <div class="border border-1 rounded m-1 p-2">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <NavLink href="@($"/vocabulary/{Vocabulary.Id}")" class="fw-bold text-primary text-decoration-none">
                    @Vocabulary.Name
                </NavLink>
            </div>
            <div class="d-flex">
                <NavLink href="@($"/vocabulary/{Vocabulary.Id}")" class="btn btn-link btn-sm text-secondary text-decoration-none m-lg-1">
                    @SharedLoc["Btn_Load"]
                </NavLink>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public required VocabularyView Vocabulary { get; set; }
}
