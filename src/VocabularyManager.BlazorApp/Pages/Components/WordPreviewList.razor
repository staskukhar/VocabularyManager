@using VocabularyManager.UseCases.DTOs

<div class="flex-row">
    <h5>Preview (@Words.Count words)</h5>
    @for (int i = StartOfPage(CurrentPage); i < EndOfPage(CurrentPage); i++)
    {
        <div class="card mb-1 p-2 border-1 bg-transparent">
            <div class="d-flex align-items-center">
                <span class="text-muted me-2">@PositionLabelText(i + 1):</span>
                <span class="fw-bold text-primary">@Words[i].WordContent</span>
                @if (Words[i].Meanings?.Any() == true)
                {
                    <span class="badge bg-secondary ms-2">
                        @Words[i].Meanings.Count @(Words[i].Meanings.Count == 1 ? "meaning" : "meanings")
                    </span>
                }
                else
                {
                    <span class="badge bg-light text-muted ms-2">No meanings</span>
                }
            </div>
        </div>
    }
</div>
<Pagination ActivePageNumber="@CurrentPage"
            TotalPages="@TotalPages"
            PageChanged="OnPageChangedAsync" />

@code {
    [Parameter]
    public List<WordDTO> Words { get; set; } = new();

    [Parameter]
    public int PageSize { get; set; } = 50;

    private int CurrentPage { get; set; } = 1;

    private int TotalPages => (int)Math.Ceiling(Words.Count * 1m / PageSize);

    private int StartOfPage(int currentPage) => (currentPage - 1) * PageSize;
    
    private int EndOfPage(int currentPage)
    {
        int end = currentPage * PageSize;
        return end > Words.Count ? Words.Count : end;
    }

    private string PositionLabelText(int index)
    {
        if (index == 1) return string.Concat(index, "st");
        else if (index == 2) return string.Concat(index, "nd");
        else if (index == 3) return string.Concat(index, "rd");
        else return string.Concat(index, "th");
    }

    private async Task OnPageChangedAsync(int newPageNumber)
    {
        await Task.Run(() => { CurrentPage = newPageNumber; });
    }

    public void ResetPage()
    {
        CurrentPage = 1;
    }
}
